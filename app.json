{
  "expo": {
    "name": "Scamly",
    "slug": "scamly-app",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icons/default-icon.png",
    "scheme": "scamlyapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.scamly.app",
      "icon": "./assets/images/icons/ios.icon",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Allow access to your photos so you can upload screenshots to the scanning tool."
      },
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icons/android/android-icon-foreground.png",
        "backgroundImage": "./assets/images/icons/android/android-icon-background.png",
        "monochromeImage": "./assets/images/icons/android/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "io.scamly.app",
      "playStoreUrl": "https://play.google.com/store/apps/details?id=io.scamly.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#A14BFB",
          "dark": {
            "backgroundColor": "#A14BFB"
          }
        }
      ],
      "expo-localization",
      [
        "@sentry/react-native/expo",
        {
          "organization": "scamly",
          "project": "scamly-app"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.70395534373-qvv18ad8a50r7a0cdt3mt1lafteuu5d6"
        }
      ],
      "@sentry/react-native",
      [
        "expo-apple-authentication"
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "appRoot": "app"
      },
      "eas": {
        "projectId": "2609a083-c868-41d9-a2f0-0de59a2189dd"
      }
    },
    "owner": "scamly"
  }
}
